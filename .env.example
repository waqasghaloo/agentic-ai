# Copy this file to .env and fill in your actual values
# Never commit .env to git

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs voiceover
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# fal.ai — images + video clips
FAL_KEY=your_fal_api_key_here
# Image model: Flux Pro v1.1 (~$0.05/image). Budget: fal-ai/flux/schnell (~$0.003/image)
FAL_IMAGE_MODEL=fal-ai/flux-pro/v1.1
# Video clip model: WAN 2.1 (~$0.03-0.05/clip). Premium: fal-ai/kling-video/v2.0/standard/text-to-video
FAL_VIDEO_MODEL=fal-ai/wan/v2.1/t2v

# Optional: Pexels free stock footage (sign up at pexels.com/api)
PEXELS_API_KEY=your_pexels_api_key_here

# OPENAI_API_KEY=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
